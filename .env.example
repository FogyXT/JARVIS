# === REQUIRED ===
# Get your API keys from:
#   Anthropic:  https://console.anthropic.com/
#   DeepSeek:   https://platform.deepseek.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
HF_TOKEN=your_huggingface_token_here

# === Minecraft RCON (optional) ===
MC_RCON_PASSWORD=mc_password
MC_RCON_HOST=localhost
MC_RCON_PORT=25575
MC_SERVER_DIR=C:/path/to/minecraft/server

# === Web UI Auth (optional) ===
WEBUI_USER=admin
WEBUI_PASS=your_secure_password
WEBUI_HOST=127.0.0.1
FLASK_SECRET_KEY=generate_a_random_secret_here
